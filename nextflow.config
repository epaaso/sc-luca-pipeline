profiles {
    local {
        process {
            executor = 'local'
        }
        singularity {
            enabled = true
            autoMounts = true
            runOptions = '--nv --bind /datos,/data,/home,/datos/home'
        }
    }

    remote_gpu {
        process {
            executor = 'slurm'
        }
        executor {
            name = 'slurm'
            queueSize = 20
            submitRateLimit = '10 sec'
        }
        singularity {
            enabled = true
            autoMounts = true
            runOptions = '--nv --bind /datos,/data,/home,/datos/home'
        }
    }
}

// Default to local profile if none specified
defaultProfile = 'local'
